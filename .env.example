# LLM provider: auto, openai, ollama
LLM_PROVIDER=auto

# OpenAI-compatible endpoint (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Local Ollama (recommended for your use case)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:27b
OLLAMA_TIMEOUT_SECONDS=1800
OLLAMA_KEEP_ALIVE=30m
OLLAMA_UNLOAD_AFTER_TASK=true
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=800

# Safety and cache
CACHE_DIR=.cache/game-product-analytics
STEAM_MIN_REQUEST_INTERVAL_SECONDS=1.2
STEAM_PAGE_DELAY_SECONDS=1.2
STEAM_MAX_RETRIES=3
STEAM_RETRY_BASE_SECONDS=1.5
STEAM_RETRY_MAX_SECONDS=15
STEAM_RATE_LIMIT_COOLDOWN_SECONDS=3600
STEAM_FORBIDDEN_COOLDOWN_SECONDS=86400
STEAM_SEARCH_CACHE_TTL_SECONDS=2592000
STEAM_REVIEWS_CACHE_TTL_SECONDS=604800
ANALYSIS_CACHE_TTL_SECONDS=604800
